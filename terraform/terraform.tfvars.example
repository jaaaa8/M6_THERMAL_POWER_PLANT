# JWT Secret (có thể dùng cái mặc định hoặc generate mới)
jwt_secret = "eWVsbG93d29vZGVub3JnYW5pemVkZGlzdGFuY2Vkcml2aW5nbGVhZGJyYXNzYnJlYXQ="

# Gmail để gửi email thông báo
