# ================================================================
#  terraform.tfvars — Điền các giá trị bí mật vào đây
#  ⚠️  File này đã được thêm vào .gitignore — KHÔNG commit lên Git!
# ================================================================

# IP public của bạn — dùng để giới hạn SSH vào Jenkins (curl ifconfig.me để lấy)
my_ip = "1.2.3.4"

# MySQL password (đặt password mạnh của bạn)
db_password = "YourStrongPassword123!"

# JWT Secret — BẮT BUỘC tự generate (KHÔNG dùng lại secret cũ trong lịch sử git, đã bị lộ)
# Cách tạo: openssl rand -base64 48
jwt_secret = "REPLACE_ME_WITH_YOUR_OWN_GENERATED_SECRET"

# Gmail để gửi email thông báo
mail_username = "your-email@gmail.com"
mail_password = "your-gmail-app-password"
